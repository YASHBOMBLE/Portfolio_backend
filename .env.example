# ==========================================
# SERVER
# ==========================================
PORT=5000
NODE_ENV=production
# Comma-separated list of allowed origins for CORS (your live frontend URLs)
CLIENT_ORIGIN=http://localhost:5500,https://yourdomain.com

# ==========================================
# POSTGRESQL DATABASE (managed via pgAdmin)
# ==========================================
PGHOST=localhost
PGPORT=5432
PGDATABASE=portfolio_db
PGUSER=postgres
PGPASSWORD=your_postgres_password
# If your host requires SSL (most cloud Postgres providers do), set to true
PGSSL=false

# ==========================================
# JWT (admin panel authentication)
# ==========================================
JWT_SECRET=replace_this_with_a_long_random_string
JWT_EXPIRES_IN=8h

# ==========================================
# ADMIN ACCOUNT (used once by scripts/initDb.js to create the first admin)
# ==========================================
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeThisPassword123!

# ==========================================
# EMAIL (SMTP) - used to notify admin + auto-reply to visitor
# Example below uses Gmail SMTP with an App Password.
# You can swap in any SMTP provider (SendGrid, Mailgun, Zoho, etc.)
# ==========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=youraddress@gmail.com
SMTP_PASSWORD=your_gmail_app_password
# Email that receives new-message notifications (usually same as SMTP_USER)
ADMIN_NOTIFICATION_EMAIL=youraddress@gmail.com
# "From" name/address shown to visitors on the auto-reply
MAIL_FROM_NAME=Your Name
MAIL_FROM_ADDRESS=youraddress@gmail.com
